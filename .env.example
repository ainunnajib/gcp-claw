# GCPClaw Configuration
# Copy this to .env and fill in your API keys

# Model provider keys (set at least one)
GOOGLE_API_KEY=              # For Gemini models
ANTHROPIC_API_KEY=           # For Claude models (via LiteLLM)
OPENAI_API_KEY=              # For GPT models (via LiteLLM)

# Default model (LiteLLM format: provider/model-name)
# Examples: gemini-2.0-flash, anthropic/claude-sonnet-4-6, openai/gpt-4o
AGENT_MODEL=gemini-2.0-flash

# Workspace directory for sandboxed file operations
WORKSPACE_DIR=./workspace

# Security controls (enterprise defaults are locked down)
ENABLE_DANGEROUS_TOOLS=false      # Enables run_command/create_extension/remove_extension
ENABLE_EXTENSION_EXECUTION=false  # Enables loading and executing extension tools

# Web search (optional — pick one)
SERPAPI_API_KEY=              # For SerpAPI web search
GOOGLE_CSE_ID=               # For Google Custom Search
GOOGLE_CSE_API_KEY=          # For Google Custom Search
